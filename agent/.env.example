# -----------------------------------------------------------------------------
# CreditLayer Agent Environment Variables
# Copy this file to `.env` in the same folder.
# -----------------------------------------------------------------------------
# cp .env.example .env
#
# Required = needed for full AI behavior
# Optional = service still runs with graceful fallback
# -----------------------------------------------------------------------------

# OPTIONAL (recommended)
# Anthropic API key for:
# - anomaly_check_node (Sybil / gaming penalty)
# - natural language report generation
# If omitted, agent returns deterministic fallback text and skips AI reasoning.
ANTHROPIC_API_KEY=

# OPTIONAL
# Redis connection URL for score caching.
# If Redis is unreachable, caching is disabled automatically.
REDIS_URL=redis://localhost:6379

# OPTIONAL (recommended)
# RPC endpoint used by wallet-age estimation in the data fetcher.
# If missing, wallet-age feature may degrade to 0.
RPC_URL=https://mainnet.base.org

# OPTIONAL
# Alternative fallback variable read by the wallet-age estimator.
# Used only if RPC_URL is not set.
WEB3_RPC_URL=
