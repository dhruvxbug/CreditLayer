# -----------------------------------------------------------------------------
# CreditLayer Contracts (Foundry) Environment Variables
# Used by scripts in `contracts/script/*.s.sol`
# -----------------------------------------------------------------------------
# Copy this file to `.env` in the `contracts/` folder.
# cp .env.example .env
#
# NOTE: Foundry loads env vars for vm.env* calls used in Deploy/Seed scripts.
# -----------------------------------------------------------------------------

# -----------------------------
# Deploy.s.sol variables
# -----------------------------

# REQUIRED
# Address that signs EIP-712 score attestations accepted by CreditOracle.
TRUSTED_SIGNER=0x0000000000000000000000000000000000000000

# REQUIRED
# Chainlink ETH/USD feed address for your target network.
# Base Sepolia value should be set from Chainlink docs.
CHAINLINK_ETH_USD=0x0000000000000000000000000000000000000000

# REQUIRED BY SCRIPT INPUT
# ZK verifier contract address.
# Use zero address to disable verifier checks on testnet:
# 0x0000000000000000000000000000000000000000
ZK_VERIFIER=0x0000000000000000000000000000000000000000

# OPTIONAL
# Needed only if you run `forge verify-contract` / `--verify` flows.
BASESCAN_API_KEY=

# -----------------------------
# Seed.s.sol variables
# -----------------------------

# REQUIRED FOR SEED SCRIPT
MOCK_USDC=0x0000000000000000000000000000000000000000
CREDIT_SCORE_NFT=0x0000000000000000000000000000000000000000
CREDIT_ORACLE=0x0000000000000000000000000000000000000000
LENDING_POOL=0x0000000000000000000000000000000000000000
TEST_WALLET_A=0x0000000000000000000000000000000000000000
TEST_WALLET_B=0x0000000000000000000000000000000000000000

# OPTIONAL (default false)
# true  -> local admin bypass score seeding path
# false -> signature-based oracle submission path
USE_ADMIN_SEED=true

# REQUIRED ONLY WHEN USE_ADMIN_SEED=false
# Signature-based seeding vars for Wallet A and Wallet B.
WALLET_A_SIG=0x
WALLET_B_SIG=0x
WALLET_A_TS=0
WALLET_B_TS=0

# -----------------------------
# Foundry runtime helper vars
# -----------------------------

# OPTIONAL (common in Foundry workflows)
# You can use one of these patterns depending on your setup:
# PRIVATE_KEY=0x...
# ETH_RPC_URL=https://...
# These are not directly read by vm.env* in scripts above, but often used in
# command flags, shell aliases, or CI scripts.
PRIVATE_KEY=
ETH_RPC_URL=
