# -----------------------------------------------------------------------------
# CreditLayer Frontend Environment Variables
# Copy this file to `.env.local` in the same folder.
# -----------------------------------------------------------------------------
# cp .env.example .env.local
#
# Required = app features will break if missing
# Optional = app can run with fallback behavior
# -----------------------------------------------------------------------------

# REQUIRED
# Base Sepolia (or your target chain) RPC URL used by wagmi + viem.
# Example providers: Alchemy, Infura, QuickNode, Ankr, public RPC.
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org

# OPTIONAL
# WalletConnect Cloud Project ID.
# If empty, the app falls back to injected connector (e.g. MetaMask only).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# REQUIRED (for real contract interactions)
# Deployed CreditScoreNFT contract address.
NEXT_PUBLIC_CREDIT_SCORE_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# REQUIRED (for real contract interactions)
# Deployed CreditLendingPool contract address.
NEXT_PUBLIC_LENDING_POOL_ADDRESS=0x0000000000000000000000000000000000000000

# REQUIRED (used by app contract registry and oracle-related flows)
# Deployed CreditOracle contract address.
NEXT_PUBLIC_CREDIT_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# REQUIRED (for balance/approval UX and address registry)
# Deployed MockUSDC or USDC token contract address.
NEXT_PUBLIC_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# REQUIRED (for score explorer report/features)
# URL of the Python scoring agent.
# Local example: http://localhost:8000
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
